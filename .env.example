AUTHORIZATION_KEY=your_authorization_key_here
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# ── Google Sheets ─────────────────────────────────────────────────────────────
# The long ID from your Sheet URL:
#   https://docs.google.com/spreadsheets/d/THIS_PART/edit
GOOGLE_SHEET_ID=your_google_sheet_id_here

# Name of the tab/worksheet inside the spreadsheet (default: Sheet1)
GOOGLE_SHEET_TAB=Sheet1

# Path to the Service Account JSON key file.
# On local machine: keep the file in the project root as service_account.json
# On Docker/VPS:    it is mounted into /app/service_account.json automatically
GOOGLE_SERVICE_ACCOUNT_JSON=service_account.json

# ── VPS / Docker only ─────────────────────────────────────────────────────────
# Cloudflare blocks requests from datacenter IPs.
# Set this to route traffic through a proxy (SSH tunnel or residential proxy).
#
# Option A — SSH SOCKS5 tunnel (run this on your VPS first):
#   ssh -D 1080 -N -f -i ~/.ssh/id_rsa your_user@your-home-or-proxy-ip
#   PROXY_URL=socks5h://127.0.0.1:1080
#
# Option B — HTTP/HTTPS proxy:
#   PROXY_URL=http://user:pass@proxy-host:port
#
# Leave blank if running locally (no proxy needed).
PROXY_URL=
